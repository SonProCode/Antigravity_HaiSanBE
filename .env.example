# Database
DATABASE_URL="postgresql://haisan:haisan_pass@localhost:5432/haisan_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="changeme_access_secret_very_long_and_secure"
JWT_REFRESH_SECRET="changeme_refresh_secret_very_long_and_secure"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# App
PORT=3001
NODE_ENV=development

# SMTP (example for notification jobs)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASSWORD=""
